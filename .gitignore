# Build output (the reconstructed, playable port — contains game assets)
/build/

# Packaged desktop app output (executable + bundled game assets)
/dist/

# Electron build dependencies (downloaded by npm install)
/electron/node_modules/

# Generated app icon (derived from the user's game files at build time)
/electron/game-icon.ico

# Python
__pycache__/
*.pyc

# OS / editor cruft
.DS_Store
Thumbs.db
*.swp
.idea/
.vscode/
