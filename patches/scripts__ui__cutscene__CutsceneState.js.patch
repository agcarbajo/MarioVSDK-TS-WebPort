+            ctx.lineTo(x + r, y + h);
+            ctx.quadraticCurveTo(x, y + h, x, y + h - r);
+            ctx.lineTo(x, y + r);
+            ctx.quadraticCurveTo(x, y, x + r, y);
+            ctx.fill();
+
+            ctx.globalAlpha = 1;
+            ctx.lineWidth = Math.max(2, Math.round(fontSize * 0.11));
+            ctx.strokeStyle = 'rgba(0,0,0,0.65)';
+            ctx.fillStyle = '#ffffff';
+            ctx.strokeText(text, x + w / 2, y + h / 2);
